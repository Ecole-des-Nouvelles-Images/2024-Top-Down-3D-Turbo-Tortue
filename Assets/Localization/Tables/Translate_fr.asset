  - m_Id: 52224941633536
    m_Localized: "capacit\xE9s des fleurs"
    m_Metadata:
      m_Items: []
  - m_Id: 52377073233920
    m_Localized: "capacit\xE9s de Turbo Tortue"
    m_Metadata:
      m_Items: []
  - m_Id: 70555631366144
    m_Localized: "se cacher, survivre \net \xE9puiser la tortue"
    m_Metadata:
      m_Items: []
  - m_Id: 70715996385280
    m_Localized: "\xE9liminer les fleurs avant que la batterie ne se vide"
    m_Metadata:
      m_Items: []
  - m_Id: 71383066882048
    m_Localized: retour
    m_Metadata:
      m_Items: []
  - m_Id: 71684834471936
    m_Localized: "\xE9nergie"
    m_Metadata:
      m_Items: []
  - m_Id: 71950996615168
    m_Localized: "R\xE9animation"
    m_Metadata:
      m_Items: []
  - m_Id: 72717891547136
    m_Localized: "ramasser des soleils sur la map pour utiliser les capacit\xE9s"
    m_Metadata:
      m_Items: []
  - m_Id: 73052739612672
    m_Localized: ramasser des soleils sur la map pour recharger la batterie
    m_Metadata:
      m_Items: []
  - m_Id: 73353655758848
    m_Localized: "lorsqu\u2019un joueur poss\xE8de 3 soleils, il peut r\xE9animer
      une fleur \xE9limin\xE9e en s\u2019approchant et en maintenant l\u2019action
      de r\xE9animation.\nles 3 soleils sont consomm\xE9s."
    m_Metadata:
      m_Items: []
  - m_Id: 75096028360704
    m_Localized: Fleurs
    m_Metadata:
      m_Items: []
  - m_Id: 75140752224256
