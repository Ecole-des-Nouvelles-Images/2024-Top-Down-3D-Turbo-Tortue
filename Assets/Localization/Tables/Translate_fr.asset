    m_Metadata:
      m_Items: []
  - m_Id: 414699897761792
    m_Localized: Charge rotative
    m_Metadata:
      m_Items: []
  - m_Id: 414978265329664
    m_Localized: Attaque tranchante
    m_Metadata:
      m_Items: []
  - m_Id: 415292838129664
    m_Localized: "acc\xE9l\xE9rateur co\xFBteux"
    m_Metadata:
      m_Items: []
  - m_Id: 415614163759104
    m_Localized: "scan r\xE9v\xE9lateur"
    m_Metadata:
      m_Items: []
  - m_Id: 416222107152384
    m_Localized: "pi\xE8ge \xE9lectrique"
    m_Metadata:
      m_Items: []
  - m_Id: 417629656854528
    m_Localized: "turbotortue rentre dans sa carapace et tourne sur elle m\xEAme,
      elle fonce vers l'avant quand le bouton est relach\xE9.\n\n-niveau 1 : charge
      de 1s\n-niveau 2 : charge de 1.5s  \n(permet de casser certains obstacle et
      d'\xE9tourdir les fleurs)"
    m_Metadata:
      m_Items: []
  - m_Id: 417752331857920
    m_Localized: "les r\xE9acteurs de turbotortue surchauffent, octroie une vitesse
      accrue."
    m_Metadata:
      m_Items: []
  - m_Id: 418191228022784
    m_Localized: "turbotortue active un scan d'une port\xE9e limit\xE9e qui detecte
      les fleurs \xE0 travers les obstacles."
    m_Metadata:
      m_Items: []
  - m_Id: 418911813644288
    m_Localized: "turbotortue pose une mine au sol, qui \xE9tourdit les fleurs \xE0
      son contact (5 mines actives maximum)."
    m_Metadata:
      m_Items: []
