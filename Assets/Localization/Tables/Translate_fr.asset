    m_Metadata:
      m_Items: []
  - m_Id: 76195443519488
    m_Localized: se cacher sous terre
    m_Metadata:
      m_Items: []
  - m_Id: 76557936242688
    m_Localized: "maintenir pour r\xE9animer un alli\xE9"
    m_Metadata:
      m_Items: []
  - m_Id: 76675859099648
    m_Localized: "charge (maintenir puis l\xE2cher)"
    m_Metadata:
      m_Items: []
  - m_Id: 76929119563776
    m_Localized: morsure
    m_Metadata:
      m_Items: []
  - m_Id: 77163023314944
