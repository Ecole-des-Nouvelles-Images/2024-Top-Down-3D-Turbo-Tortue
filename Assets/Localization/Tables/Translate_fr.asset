      m_Items: []
  - m_Id: 83207311025004544
    m_Localized: Robuste
    m_Metadata:
      m_Items: []
  - m_Id: 83225302634618880
    m_Localized: MORSURE
    m_Metadata:
      m_Items: []
  - m_Id: 83225302659784704
    m_Localized: CHARGE
    m_Metadata:
      m_Items: []
  - m_Id: 83225302659784705
    m_Localized: MINE
    m_Metadata:
      m_Items: []
  - m_Id: 83225302659784706
    m_Localized: NITRO
    m_Metadata:
      m_Items: []
  - m_Id: 83225302659784707
    m_Localized: SCAN
    m_Metadata:
      m_Items: []
  - m_Id: 83231166376468480
    m_Localized: "Se d\xE9placer (<sprite index=15>)\nActiver sa capacit\xE9 (<sprite
      index=33>)\nSe cacher sous terre (<sprite index=34>)\nR\xE9animer un alli\xE9
      (maintenir <sprite index=35>)"
    m_Metadata:
      m_Items: []
  - m_Id: 83231166397440000
    m_Localized: "Se d\xE9placer (<sprite index=15>)\nCharge (maintenir <sprite index=33>
      + <sprite index=15> pour orienter puis l\xE2cher)\nMorsure (<sprite index=34>)\nMine
      (<sprite index=35>)\nScan (<sprite index=36>)\nTurbo (maintenir <sprite index=123>
      ou <sprite index=124>)"
    m_Metadata:
      m_Items: []
  - m_Id: 83240063061483520
    m_Localized: MAINTENIR
    m_Metadata:
      m_Items: []
  - m_Id: 83240963406585856
    m_Localized: CHOIX TERRAIN
    m_Metadata:
      m_Items: []
  - m_Id: 83240963406585857
    m_Localized: PROCHAINEMENT
    m_Metadata:
      m_Items:
      - rid: 7983081613838778447
  - m_Id: 83240963406585858
